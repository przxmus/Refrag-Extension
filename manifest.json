{
  "manifest_version": 3,
  "name": "Refrag Routine Shuffler",
  "description": "Shuffles routine maps and mods using configurable constraints.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "action": {
    "default_title": "Refrag Routine Shuffler",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://play.refrag.gg/routines*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
