{
  "manifest_version": 3,
  "name": "Refrag+",
  "description": "Adds configurable routine tools and easier navigation to Refrag.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "action": {
    "default_title": "Refrag+",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["shuffle-worker.js"],
      "matches": ["https://play.refrag.gg/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://play.refrag.gg/routines*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://play.refrag.gg/routines*"],
      "js": ["routine-links.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
